# STOCKER — Environment Variables
# Copy this file to .env.local and fill in your keys.
# Never commit .env.local to version control.

# Database (Prisma)
DATABASE_URL=file:../data/portfolio.db

# Anthropic — LLM advisor
ANTHROPIC_API_KEY=your-anthropic-api-key

# Financial Modeling Prep — symbol search and fallback single-symbol quotes
FMP_API_KEY=your-fmp-api-key

# Alpha Vantage — backup quote provider
ALPHA_VANTAGE_API_KEY=your-alpha-vantage-api-key

# Tiingo — batch quotes (IEX) and historical daily bars
TIINGO_API_KEY=your-tiingo-api-key
TIINGO_RPH=50       # Tiingo requests per hour (free tier: 50)
TIINGO_RPD=1000      # Tiingo requests per day (free tier: 1000)

# GNews — news feed on holding detail page
# If absent, the news section falls back to a single Google News link card.
GNEWS_API_KEY=your-gnews-api-key

# CoinGecko — crypto quotes and history (no API key required)
COINGECKO_RPM=100   # CoinGecko requests per minute (free tier: ~100)
